{
  "buildCommand": "pip install -r requirements.txt",
  "env": {
    "SPOTIFY_TOKEN": "@spotify_token",
    "SLACK_WEBHOOK": "@slack_webhook",
    "CRON_SECRET": "@cron_secret"
  },
  "functions": {
    "api/functions/fraud_daily.py": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/functions/fraud_daily",
      "schedule": "0 7 * * *"
    }
  ]
}
